{
  "name": "midnight-automation-voyage",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "build:standalone": "node scripts/package-standalone.mjs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:training": "pnpm --filter playwright-learning-app dev",
    "dev:practice": "pnpm --filter practice-app dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.0"
  },
  "lint-staged": {
    "training-app/**/*.{ts,tsx}": [
      "pnpm --filter playwright-learning-app exec -- eslint --fix"
    ],
    "practice-app/**/*.{ts,tsx}": [
      "pnpm --filter practice-app exec -- eslint --fix"
    ]
  }
}
